{
	admin off
	persist_config off
	auto_https off
	servers {
		timeouts {
			read_header 10s
			read_body 30s
			idle 5m
		}
		max_header_size 32KB
		0rtt off
	}
}

:80 {
	log {
		format json
	}
	respond "LIQI edge is staged but traffic is not enabled" 503
}

:443 {
	bind 0.0.0.0 ::
	tls /etc/caddy/preactivation.crt /etc/caddy/preactivation.key
	log {
		format json
	}
	respond "LIQI edge is staged but traffic is not enabled" 503
}
