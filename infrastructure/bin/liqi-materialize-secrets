#!/usr/bin/env python3
"""Fetch OCI Vault bundles through instance principal into transient per-service credentials."""
from __future__ import annotations
import argparse, base64, binascii, json, os, pwd, grp, re, shutil, subprocess, tempfile
from pathlib import Path

NAME=re.compile(r"^[a-z][a-z0-9-]{1,63}$"); OCID=re.compile(r"^ocid1\.vaultsecret\.")
SERVICES={"beam":"liqi-beam","liqi-api":"liqi-api","liqi-realtime":"liqi-realtime","liqi-worker":"liqi-worker","database":"postgres"}

def parse()->argparse.Namespace:
    p=argparse.ArgumentParser(); group=p.add_mutually_exclusive_group(required=True); group.add_argument("--mapping",type=Path); group.add_argument("--mapping-root",type=Path); return p.parse_args()
def fetch(secret_ocid:str,stage:str)->bytes:
    command=["/usr/bin/oci","secrets","secret-bundle","get","--auth","instance_principal","--secret-id",secret_ocid,"--stage",stage,"--query",'data."secret-bundle-content".content',"--raw-output"]
    encoded=subprocess.check_output(command,text=True,stderr=subprocess.PIPE,timeout=45).strip()
    try: value=base64.b64decode(encoded,validate=True)
    except binascii.Error as error: raise RuntimeError("OCI returned invalid base64 secret content") from error
    if not value or len(value)>25*1024: raise RuntimeError("secret content is empty or exceeds OCI 25 KiB bundle limit")
    return value
def mapping_paths(a:argparse.Namespace)->list[Path]:
    if a.mapping: return [a.mapping]
    paths=sorted(a.mapping_root.glob("*.json"));
    if not paths: raise SystemExit("no service secret mappings found")
    return paths
def materialize(path:Path)->None:
    mapping=json.loads(path.read_text(encoding="utf-8")); service=mapping.get("service")
    if mapping.get("schema_version")!="liqi.infrastructure.secret-mapping/v1" or service not in SERVICES: raise SystemExit(f"unsupported secret mapping: {path}")
    if path.stem!=service: raise SystemExit(f"mapping filename must be {service}.json")
    credentials=mapping.get("credentials")
    if not isinstance(credentials,list) or not credentials: raise SystemExit("mapping must contain credentials")
    user=SERVICES[service]; uid=pwd.getpwnam(user).pw_uid; gid=grp.getgrnam("liqi").gr_gid
    root=Path("/run/liqi/secrets"); root.mkdir(parents=True,exist_ok=True); target=root/service
    staging=Path(tempfile.mkdtemp(prefix=f".{service}.",dir=root)); os.chmod(staging,0o700); os.chown(staging,uid,gid)
    seen=set()
    try:
        for item in credentials:
            name=item.get("name"); ocid=item.get("secret_ocid"); stage=item.get("stage")
            if not isinstance(name,str) or not NAME.fullmatch(name) or name in seen: raise SystemExit("invalid or duplicate credential name")
            if not isinstance(ocid,str) or not OCID.match(ocid) or stage not in {"CURRENT","PENDING","PREVIOUS"}: raise SystemExit(f"invalid Vault reference for {name}")
            seen.add(name); value=fetch(ocid,stage); credential=staging/name
            with credential.open("xb") as handle: handle.write(value); handle.flush(); os.fsync(handle.fileno())
            os.chown(credential,uid,gid); os.chmod(credential,0o400)
        previous=root/f".{service}.previous"; shutil.rmtree(previous,ignore_errors=True)
        if target.exists(): target.rename(previous)
        staging.rename(target); shutil.rmtree(previous,ignore_errors=True)
    except Exception:
        shutil.rmtree(staging,ignore_errors=True); raise
def main()->int:
    a=parse()
    for path in mapping_paths(a): materialize(path)
    return 0
if __name__=="__main__": raise SystemExit(main())
