#!/usr/bin/env python3
"""Apply approved database login credentials and recreate transient consumers."""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import subprocess
from datetime import datetime, timezone
from pathlib import Path
from urllib.parse import quote, urlunsplit

ROLES = (
    "liqi_migrator", "liqi_api", "liqi_realtime", "liqi_worker",
    "liqi_readonly", "liqi_monitor", "liqi_backup",
)
RUNTIME_ROLES = {"command": "liqi_api", "realtime": "liqi_realtime", "worker": "liqi_worker"}
POOL_ROLES = ("liqi_api", "liqi_realtime", "liqi_worker", "liqi_readonly", "liqi_monitor")
VALUE = re.compile(r"^[^\x00\r\n]{16,256}$")


def utc() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def digest(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def load_bundle(path: Path) -> dict[str, str]:
    document = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(document, dict) or set(document) != set(ROLES):
        raise RuntimeError("database login bundle must contain the exact role set")
    for role, value in document.items():
        if not isinstance(value, str) or not VALUE.fullmatch(value):
            raise RuntimeError(f"invalid credential shape for {role}")
    return document


def psql(stdin: str, query: bool = False) -> str:
    command = [
        "/usr/sbin/runuser", "-u", "postgres", "--", "/usr/pgsql-17/bin/psql",
        "--no-psqlrc", "--quiet", "--set=ON_ERROR_STOP=1", "--dbname=postgres",
    ]
    if query:
        command += ["--tuples-only", "--no-align", "--field-separator", "\t"]
    result = subprocess.run(command, input=stdin, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False, timeout=60)
    if result.returncode:
        raise RuntimeError(result.stderr.strip() or "local PostgreSQL credential operation failed")
    return result.stdout


def literal(value: str) -> str:
    return "'" + value.replace("'", "''") + "'"


def apply_logins(bundle: dict[str, str]) -> None:
    statements = [f'ALTER ROLE "{role}" PASSWORD {literal(bundle[role])};' for role in ROLES]
    psql("BEGIN;\n" + "\n".join(statements) + "\nCOMMIT;\n")


def read_verifiers() -> dict[str, str]:
    names = ",".join(literal(role) for role in ROLES)
    output = psql(f"SELECT rolname, rolpassword FROM pg_authid WHERE rolname IN ({names}) ORDER BY rolname;\n", query=True)
    result: dict[str, str] = {}
    for line in output.splitlines():
        if not line.strip():
            continue
        role, separator, verifier = line.partition("\t")
        if not separator or role not in ROLES or not verifier.startswith("SCRAM-SHA-256$"):
            raise RuntimeError("PostgreSQL returned an invalid SCRAM verifier")
        result[role] = verifier
    if set(result) != set(ROLES):
        raise RuntimeError("PostgreSQL SCRAM verifier set is incomplete")
    return result


def atomic_secret(path: Path, data: bytes, user: str, group: str) -> None:
    import pwd
    import grp
    uid = pwd.getpwnam(user).pw_uid
    gid = grp.getgrnam(group).gr_gid
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.new.{os.getpid()}")
    with temporary.open("xb") as stream:
        stream.write(data)
        stream.flush()
        os.fsync(stream.fileno())
    os.chown(temporary, uid, gid)
    os.chmod(temporary, 0o400)
    os.replace(temporary, path)


def write_evidence(path: Path, document: dict[str, object]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.new.{os.getpid()}")
    temporary.write_text(json.dumps(document, indent=2, sort_keys=True) + "\n", encoding="utf-8", newline="\n")
    os.chmod(temporary, 0o440)
    os.replace(temporary, path)


def role_url(role: str, value: str) -> str:
    userinfo = role + ":" + quote(value, safe="")
    return urlunsplit(("postgresql", userinfo + "@127.0.0.1:6432", "/liqi", "", ""))


def pgpass_line(host: str, port: str, role: str, value: str) -> str:
    escaped = value.replace("\\", "\\\\").replace(":", "\\:")
    return ":".join((host, port, "liqi", role, escaped)) + "\n"


def materialize(bundle: dict[str, str]) -> None:
    verifiers = read_verifiers()
    lines = [json.dumps(role) + " " + json.dumps(verifiers[role]) for role in POOL_ROLES]
    atomic_secret(
        Path("/run/liqi/secrets/database/pgbouncer-userlist.txt"),
        ("\n".join(lines) + "\n").encode(), "pgbouncer", "pgbouncer",
    )
    local_files = {
        "migrator-pgpass": pgpass_line("/run/postgresql", "5432", "liqi_migrator", bundle["liqi_migrator"]),
        "monitor-pgpass": pgpass_line("127.0.0.1", "6432", "liqi_monitor", bundle["liqi_monitor"]),
        "backup-pgpass": pgpass_line("/run/postgresql", "5432", "liqi_backup", bundle["liqi_backup"]),
    }
    for name, value in local_files.items():
        atomic_secret(Path("/run/liqi/secrets/database") / name, value.encode(), "postgres", "liqi")
    urls = {key: role_url(role, bundle[role]) for key, role in RUNTIME_ROLES.items()}
    atomic_secret(
        Path("/run/liqi/secrets/beam/database-role-urls"),
        (json.dumps(urls, sort_keys=True, separators=(",", ":")) + "\n").encode(),
        "liqi-beam", "liqi",
    )


def result_document(status: str, bundle_sha: str, approval: str | None, mutation: bool) -> dict[str, object]:
    return {
        "schema_version": "liqi.infrastructure.database-credentials/v1",
        "status": status,
        "bundle_sha256": bundle_sha,
        "roles": list(ROLES),
        "runtime_bundle_path": "/run/liqi/secrets/beam/database-role-urls",
        "pgbouncer_userlist_path": "/run/liqi/secrets/database/pgbouncer-userlist.txt",
        "approval_reference": approval,
        "observed_at": utc(),
        "database_mutation_performed": mutation,
    }


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("mode", choices=("apply", "restore-transient"))
    parser.add_argument("--bundle", type=Path, default=Path("/run/liqi/secrets/database/database-role-passwords"))
    parser.add_argument("--evidence", type=Path, default=Path("/var/lib/liqi/recovery/database-credentials-v1.json"))
    parser.add_argument("--approval-reference")
    parser.add_argument("--execute", action="store_true")
    parser.add_argument("--output", type=Path)
    return parser.parse_args()


def validate_execution(args: argparse.Namespace) -> None:
    if args.execute and (os.name != "posix" or os.geteuid() != 0):
        raise SystemExit("database credential operation requires root on POSIX")
    if args.mode == "apply" and args.execute:
        if not args.approval_reference or len(args.approval_reference.strip()) < 3:
            raise SystemExit("database credential apply requires approval reference")


def execute_apply(args: argparse.Namespace, bundle: dict[str, str], bundle_sha: str) -> dict[str, object]:
    apply_logins(bundle)
    materialize(bundle)
    document = result_document("applied", bundle_sha, args.approval_reference, True)
    write_evidence(args.evidence, document)
    return document


def execute_restore(args: argparse.Namespace, bundle: dict[str, str], bundle_sha: str) -> dict[str, object]:
    approved = json.loads(args.evidence.read_text(encoding="utf-8"))
    if approved.get("schema_version") != "liqi.infrastructure.database-credentials/v1":
        raise RuntimeError("database credential evidence has an unsupported schema")
    if approved.get("status") != "applied" or approved.get("bundle_sha256") != bundle_sha:
        raise RuntimeError("current bundle does not match approved database credential evidence")
    materialize(bundle)
    return result_document("restored", bundle_sha, approved.get("approval_reference"), False)


def main() -> int:
    args = parse_args()
    validate_execution(args)
    bundle = load_bundle(args.bundle)
    bundle_sha = digest(args.bundle)
    if not args.execute:
        document = result_document("planned", bundle_sha, None, False)
    elif args.mode == "apply":
        document = execute_apply(args, bundle, bundle_sha)
    else:
        document = execute_restore(args, bundle, bundle_sha)
    if args.output is not None:
        write_evidence(args.output, document)
    print(json.dumps(document, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
