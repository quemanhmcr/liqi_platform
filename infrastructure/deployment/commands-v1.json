{
  "schema_version": "liqi.infrastructure.provider-commands/v1",
  "environment": "v1-live",
  "default_mutation_policy": "dry-run-or-read-only",
  "commands": [
    {
      "id": "source-validation",
      "command": [
        "python",
        "infrastructure/validation/validate_v1_source.py"
      ],
      "working_directory": "repository-root",
      "mutation": "none",
      "output": "stdout"
    },
    {
      "id": "discover-e5-adoption",
      "command": [
        "python",
        "infrastructure/deployment/discover_v1_live_adoption.py",
        "--resource-names",
        "infrastructure/opentofu/environments/v1-live/resource-names.e5-adoption.example.json",
        "--output",
        "<adoption-manifest-v1.json>"
      ],
      "working_directory": "repository-root-clean",
      "required_environment": [
        "OCI CLI authenticated for ap-singapore-2"
      ],
      "mutation": "read-only-oci-discovery",
      "output": "adoption-manifest-v1"
    },
    {
      "id": "validate-e5-state-adoption",
      "command": [
        "python",
        "infrastructure/deployment/adopt_v1_live_state.py",
        "--manifest",
        "<adoption-manifest-v1.json>",
        "--var-file",
        "<protected-live.tfvars>",
        "--output",
        "<adoption-result-v1.json>"
      ],
      "working_directory": "repository-root-clean",
      "mutation": "none-validation-only",
      "output": "adoption-result-v1 status=validated"
    },
    {
      "id": "execute-e5-state-adoption",
      "command": [
        "python",
        "infrastructure/deployment/adopt_v1_live_state.py",
        "--manifest",
        "<adoption-manifest-v1.json>",
        "--var-file",
        "<protected-live.tfvars>",
        "--output",
        "<adoption-result-v1.json>",
        "--approval-reference",
        "<approval>",
        "--execute"
      ],
      "working_directory": "repository-root-clean",
      "required_environment": [
        "TF_ENCRYPTION",
        "PG_CONN_STR (sslmode=verify-full)",
        "PG_SCHEMA_NAME=opentofu_v1_live",
        "PG_SKIP_SCHEMA_CREATION=true",
        "PG_SKIP_TABLE_CREATION=true",
        "PG_SKIP_INDEX_CREATION=true",
        "OCI provider authentication"
      ],
      "mutation": "encrypted-opentofu-state-only-no-oci-resource-mutation",
      "output": "adoption-result-v1 status=passed"
    },
    {
      "id": "establish-first-release-recovery",
      "command": [
        "python",
        "infrastructure/deployment/establish_first_release_recovery.py",
        "--primary-instance-name",
        "liqi-live-primary",
        "--fallback-instance-name",
        "liqi-live-primary-fallback-stopped",
        "--network-load-balancer-name",
        "liqi-live-edge-nlb",
        "--backup-name",
        "<approved-full-boot-volume-backup-name>",
        "--approval-reference",
        "<approval>",
        "--execute",
        "--output",
        "<first-release-recovery-v1.json>"
      ],
      "working_directory": "repository-root-clean",
      "required_environment": [
        "OCI CLI authenticated for ap-singapore-2"
      ],
      "mutation": "approval-required-oci-backup-and-fallback-start-stop",
      "output": "first-release-recovery-v1",
      "failure_policy": "require traffic off, exact primary boot volume, AVAILABLE FULL backup no older than 24 hours, private STOPPED fallback, successful start/stop restoration, exact clean Git SHA and redacted evidence"
    },
    {
      "id": "pre-apply-readiness",
      "command": [
        "python",
        "infrastructure/validation/pre_apply_readiness.py",
        "--adoption-manifest",
        "<adoption-manifest-v1.json>",
        "--state-backend-evidence",
        "<state-backend-evidence-v1.json>",
        "--adoption-result",
        "<adoption-result-v1.json>",
        "--var-file",
        "<protected-e5.tfvars>",
        "--linux-release-build-result",
        "<linux-release-build-result-v1.json>",
        "--release-trust-dir",
        "<release-public-key-dir>",
        "--native-trust-dir",
        "<native-public-key-dir>",
        "--recovery-target",
        "<first-release-recovery-v1.json>",
        "--output",
        "<pre-apply-readiness-v1.json>"
      ],
      "working_directory": "repository-root-clean",
      "required_environment": [
        "TF_ENCRYPTION",
        "PG_CONN_STR with sslmode=verify-full",
        "PG_SCHEMA_NAME=opentofu_v1_live",
        "PG_SKIP_SCHEMA_CREATION=true",
        "PG_SKIP_TABLE_CREATION=true",
        "PG_SKIP_INDEX_CREATION=true"
      ],
      "mutation": "none",
      "output": "pre-apply-readiness-v1",
      "failure_policy": "emit blocked for incomplete handoff or missing protected inputs; fail on schema, digest, signature, recovery, symlink or secret-hygiene mismatch; never print protected values"
    },
    {
      "id": "read-only-live-plan",
      "command": [
        "infrastructure/deployment/plan_v1_live.sh",
        "--state-backend-evidence",
        "<state-backend-evidence-v1.json>",
        "--adoption-result",
        "<adoption-result-v1.json>",
        "--pre-apply-readiness",
        "<pre-apply-readiness-v1.json>",
        "--var-file",
        "<protected-live.tfvars>",
        "--output-dir",
        "<evidence-dir>",
        "--capacity-profile",
        "e5-temporary",
        "--adopt-existing"
      ],
      "working_directory": "repository-root-clean",
      "required_environment": [
        "TF_ENCRYPTION",
        "PG_CONN_STR (sslmode=verify-full)",
        "PG_SCHEMA_NAME=opentofu_v1_live",
        "PG_SKIP_SCHEMA_CREATION=true",
        "PG_SKIP_TABLE_CREATION=true",
        "PG_SKIP_INDEX_CREATION=true",
        "OCI provider authentication"
      ],
      "mutation": "read-only",
      "output": "v1-live.plan-result.json",
      "failure_policy": "reject missing or non-passed pre-apply readiness, state-adoption evidence, delete/replacement actions, architecture/profile mismatch, or unreviewed cost/expiry"
    },
    {
      "id": "approved-oci-apply",
      "command": [
        "infrastructure/deployment/apply_v1_live.sh",
        "--plan-result",
        "<v1-live.plan-result.json>",
        "--pre-apply-readiness",
        "<pre-apply-readiness-v1.json>",
        "--approval-reference",
        "<approval>",
        "--execute"
      ],
      "working_directory": "repository-root-clean",
      "required_environment": [
        "TF_ENCRYPTION",
        "PG_CONN_STR (sslmode=verify-full)",
        "PG_SCHEMA_NAME=opentofu_v1_live",
        "PG_SKIP_SCHEMA_CREATION=true",
        "PG_SKIP_TABLE_CREATION=true",
        "PG_SKIP_INDEX_CREATION=true",
        "OCI provider authentication"
      ],
      "mutation": "approval-required",
      "output": "v1-live.apply-result.json",
      "failure_policy": "refuse mutation unless the exact saved plan and the same passed pre-apply readiness file retain all state/adoption/tfvars/release/rollback digest bindings"
    },
    {
      "id": "build-host-bundle",
      "command": [
        "python",
        "infrastructure/deployment/build_host_bundle.py",
        "--git-sha",
        "<exact-sha>",
        "--bundle-id",
        "<bundle-id>",
        "--key-id",
        "<key-id>",
        "--signing-key",
        "<private-key-file>",
        "--output-dir",
        "<artifact-dir>"
      ],
      "working_directory": "repository-root-clean",
      "mutation": "local-artifact-only",
      "output": "signed host bundle, manifest and signature"
    },
    {
      "id": "archive-host-bundle",
      "command": [
        "python",
        "infrastructure/deployment/archive_host_bundle.py",
        "--bundle-dir",
        "<artifact-dir>",
        "--bundle-id",
        "<bundle-id>",
        "--public-key",
        "<public-key-file>",
        "--archive-root",
        "<independent-management-storage-root>",
        "--output",
        "<archive-evidence.json>"
      ],
      "working_directory": "repository-root-clean",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "host-bundle-archive-result-v1",
      "failure_policy": "refuse overwrite, symlink inputs, unmarked archive roots, invalid signatures or non-independent authority"
    },
    {
      "id": "authorize-native-artifact",
      "command": [
        "python",
        "infrastructure/deployment/authorize_native_artifact.py",
        "--native-manifest",
        "<Senior-3-native-artifact-v1.json>",
        "--deployment-key-id",
        "<deployment-key-id>",
        "--deployment-signing-key",
        "<private-key-file>",
        "--authorization-reference",
        "<artifact-authorization-reference>",
        "--output-dir",
        "<native-deployment-output-dir>",
        "--output-result",
        "<native-authorization-result-v1.json>"
      ],
      "working_directory": "repository-root",
      "mutation": "build-only",
      "output": "native-authorization-result-v1"
    },
    {
      "id": "build-signed-linux-release",
      "command": [
        "python",
        "beam/scripts/build_linux_release.py",
        "--release-id",
        "<release-id>",
        "--target-triple",
        "x86_64-unknown-linux-gnu",
        "--native-provider-manifest",
        "<native-artifact-v1.json>",
        "--native-deployment-manifest",
        "<native-deployment-v1.json>",
        "--native-trust-dir",
        "<native-public-key-dir>",
        "--artifact-key-id",
        "<release-artifact-key-id>",
        "--artifact-signing-key",
        "<release-artifact-private-key>",
        "--manifest-key-id",
        "<release-manifest-key-id>",
        "--manifest-signing-key",
        "<release-manifest-private-key>",
        "--first-release",
        "--output-dir",
        "<new-release-output-dir>"
      ],
      "working_directory": "repository-root-clean-linux-x86_64",
      "required_environment": [
        "OTP 28",
        "Elixir 1.20.2",
        "cosign",
        "OpenSSL",
        "network access for locked Hex dependencies"
      ],
      "mutation": "build-and-sign-artifacts-only-no-host-or-oci-mutation",
      "output": "linux-release-build-result-v1 plus mix-release-v1, runtime-artifact-result-v1 and complete native handoff",
      "failure_policy": "reject dirty source, invalid first-release/upgrade mode, architecture mismatch, invalid native provenance/signature, shared signing key identity, non-deterministic archive shape, non-portable result evidence or failed self-verification"
    },
    {
      "id": "verify-linux-release-build-result",
      "command": [
        "python",
        "beam/scripts/validate_linux_release_build_result.py",
        "--result",
        "<release-id>.linux-release-build-result-v1.json",
        "--git-sha",
        "<exact-sha>",
        "--target-triple",
        "x86_64-unknown-linux-gnu",
        "--release-trust-dir",
        "<release-public-key-dir>",
        "--native-trust-dir",
        "<native-public-key-dir>"
      ],
      "working_directory": "repository-root-clean-with-publication-directory",
      "mutation": "none",
      "output": "portable exact-SHA Linux release publication verification summary",
      "failure_policy": "reject missing, symlinked, path-escaping, checksum-mismatched, signature-invalid, Sigstore-invalid or cross-target publication evidence"
    },
    {
      "id": "prepare-mix-deployment",
      "command": [
        "python",
        "infrastructure/deployment/prepare_mix_deployment.py",
        "--provider-manifest",
        "<Senior-1-mix-release-v1.json>",
        "--provider-trust-dir",
        "<Senior-1-public-key-dir>",
        "--runtime-config",
        "<runtime-config-v1.json>",
        "--database-contract",
        "<database-runtime-v1.json>",
        "--migration-readiness",
        "<migration-readiness-v1.json>",
        "--native-manifest",
        "<Senior-3-native-artifact-v1.json>",
        "--deployment-key-id",
        "<deployment-key-id>",
        "--deployment-signing-key",
        "<private-key-file>",
        "--output-dir",
        "<deployment-artifact-dir>"
      ],
      "working_directory": "repository-root-clean",
      "mutation": "local-artifact-only",
      "output": "signed mix-deployment-v1 wrapper and self-contained provider artifacts",
      "failure_policy": "first release rejects an application rollback descriptor; upgrades require an exact compatible retained V1 descriptor; all provider evidence must be passed"
    },
    {
      "id": "stage-mix-release",
      "command": [
        "python",
        "infrastructure/deployment/stage_mix_release.py",
        "--deployment-wrapper",
        "<mix-deployment-v1.json>",
        "--artifact-dir",
        "<deployment-artifact-dir>",
        "--deployment-trust-dir",
        "<Senior-4-public-key-dir>",
        "--provider-trust-dir",
        "<Senior-1-public-key-dir>",
        "--native-trust-dir",
        "<Senior-4-native-public-key-dir>",
        "--output",
        "<installed-release-v1.json>"
      ],
      "working_directory": "repository-root-or-host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "installed-release-v1",
      "verification": "Senior 3 native/scripts/verify_artifact.py with Sigstore evidence"
    },
    {
      "id": "retain-v0-rollback",
      "command": [
        "python",
        "infrastructure/deployment/adapt_v0_rollback.py",
        "--release-manifest",
        "<release-manifest-v0.json>",
        "--deployment-spec",
        "<deployment-spec-v0.json>",
        "--health-target",
        "<health-gate-target-v0.json>",
        "--upgrade-compatibility-result",
        "<Senior-2-v0-upgrade-result.json>",
        "--database-provider-git-sha",
        "<exact-Senior-2-sha>",
        "--release-path",
        "<installed-v0-release-path>",
        "--output",
        "<v0-retention-result.json>"
      ],
      "working_directory": "host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "V0 release-target-v1 compatibility descriptor"
    },
    {
      "id": "database-auth-activation",
      "command": [
        "/usr/local/libexec/liqi-configure-database-credentials",
        "apply",
        "--bundle",
        "<vault-bundle>",
        "--approval-reference",
        "<approval>",
        "--execute",
        "--output",
        "<result.json>"
      ],
      "working_directory": "host",
      "mutation": "approval-required",
      "output": "database-credentials-v1"
    },
    {
      "id": "release-control",
      "command": [
        "python",
        "infrastructure/deployment/release_control.py",
        "activate|rollback",
        "--deployment-id",
        "<id>",
        "--target-release-id",
        "<release-id>",
        "--host-readiness",
        "<host-runtime-v1.json>",
        "--database-readiness",
        "<migration-readiness-v1.json>",
        "--first-release-recovery",
        "<first-release-recovery-v1.json>",
        "--activation-output",
        "<activation-v1.json>",
        "--rollback-output",
        "<rollback-v1.json>"
      ],
      "working_directory": "host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "activation-v1 and rollback-v1",
      "failure_policy": "first activation requires exact recovery evidence and deactivates on failure; upgrades atomically restore release and runtime-config symlinks"
    },
    {
      "id": "traffic-enable",
      "command": [
        "python",
        "infrastructure/deployment/configure_live_edge.py",
        "--hostname",
        "<hostname>",
        "--acme-email",
        "<email>",
        "--activation-evidence",
        "<activation-v1.json>",
        "--runtime-config",
        "<runtime-config-v1.json>",
        "--rendered-output",
        "<Caddyfile.rendered>",
        "--evidence-output",
        "<live-endpoint-v1.json>"
      ],
      "working_directory": "host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "live-endpoint-v1"
    },
    {
      "id": "backup-timer-enable",
      "command": [
        "python",
        "infrastructure/deployment/enable_backup_timers.py",
        "--backup-status",
        "<backup-status.json>",
        "--backup-status-checksum",
        "<backup-status.sha256>",
        "--restore-result",
        "<restore-result.json>",
        "--restore-result-checksum",
        "<restore-result.sha256>",
        "--output",
        "<timer-result.json>"
      ],
      "working_directory": "host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "backup-timer-enable-result-v1"
    }
  ]
}
