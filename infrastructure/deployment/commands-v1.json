{
  "schema_version": "liqi.infrastructure.provider-commands/v1",
  "environment": "v1-live",
  "default_mutation_policy": "dry-run-or-read-only",
  "commands": [
    {
      "id": "source-validation",
      "command": ["python", "infrastructure/validation/validate_v1_source.py"],
      "working_directory": "repository-root",
      "mutation": "none",
      "output": "stdout"
    },
    {
      "id": "read-only-live-plan",
      "command": ["infrastructure/deployment/plan_v1_live.sh", "--backend-config", "<backend.hcl>", "--var-file", "<live.tfvars>", "--output-dir", "<evidence-dir>"],
      "working_directory": "repository-root",
      "required_environment": ["TF_ENCRYPTION", "AWS_SHARED_CREDENTIALS_FILE", "OCI provider authentication"],
      "mutation": "read-only",
      "output": "v1-live.plan-result.json"
    },
    {
      "id": "approved-oci-apply",
      "command": ["infrastructure/deployment/apply_v1_live.sh", "--plan-result", "<v1-live.plan-result.json>", "--approval-reference", "<approval>", "--execute"],
      "working_directory": "repository-root",
      "required_environment": ["TF_ENCRYPTION", "AWS_SHARED_CREDENTIALS_FILE", "OCI provider authentication"],
      "mutation": "approval-required",
      "output": "v1-live.apply-result.json"
    },
    {
      "id": "build-host-bundle",
      "command": ["python", "infrastructure/deployment/build_host_bundle.py", "--git-sha", "<exact-sha>", "--bundle-id", "<bundle-id>", "--key-id", "<key-id>", "--signing-key", "<private-key-file>", "--output-dir", "<artifact-dir>"],
      "working_directory": "repository-root-clean",
      "mutation": "local-artifact-only",
      "output": "signed host bundle, manifest and signature"
    },
    {
      "id": "stage-mix-release",
      "command": ["python", "infrastructure/deployment/stage_mix_release.py", "--manifest", "<mix-manifest>", "--artifact-dir", "<artifact-dir>", "--trust-dir", "<trust-dir>", "--output", "<installed-release-evidence>"],
      "working_directory": "repository-root-or-host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "installed-release-v1"
    },
    {
      "id": "release-control",
      "command": ["python", "infrastructure/deployment/release_control.py", "activate|rollback", "--deployment-id", "<id>", "--host-readiness", "<host-evidence>", "--database-readiness", "<database-evidence>", "--rollback-output", "<rollback-evidence>"],
      "working_directory": "host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "activation-v1 and rollback-v1"
    },
    {
      "id": "traffic-enable",
      "command": ["python", "infrastructure/deployment/configure_live_edge.py", "--hostname", "<hostname>", "--acme-email", "<email>", "--activation-evidence", "<activation.json>", "--rendered-output", "<Caddyfile.rendered>", "--evidence-output", "<live-endpoint.json>"],
      "working_directory": "host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "live-endpoint-v1"
    },
    {
      "id": "backup-timer-enable",
      "command": ["python", "infrastructure/deployment/enable_backup_timers.py", "--backup-status", "<backup-status.json>", "--backup-status-checksum", "<backup-status.sha256>", "--restore-result", "<restore-result.json>", "--restore-result-checksum", "<restore-result.sha256>", "--output", "<timer-result.json>"],
      "working_directory": "host",
      "mutation": "dry-run-unless---execute-and-approval-reference",
      "output": "backup-timer-enable-result-v1"
    }
  ]
}
