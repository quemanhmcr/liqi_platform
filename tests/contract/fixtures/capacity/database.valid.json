{
  "schema_version": "capacity-budget-v0",
  "provider": "database",
  "owner": "Senior 2",
  "components": [
    {
      "name": "postgresql",
      "class": "database",
      "default_enabled": true,
      "steady_state": {
        "ocpu": 0.75,
        "memory_mib": 4096,
        "disk_gib": 60
      },
      "hard_limit": {
        "ocpu": 1.3,
        "memory_mib": 8192,
        "disk_gib": 120
      },
      "postgres_connections": 70,
      "queue": {
        "bounded": true,
        "capacity": 0,
        "overflow_behavior": "not-applicable"
      },
      "retry": {
        "maximum_attempts": 0,
        "maximum_elapsed_seconds": 0,
        "backoff": "none",
        "jitter": false
      },
      "failure_behavior": "manual-recovery"
    },
    {
      "name": "pgbouncer",
      "class": "pooler",
      "default_enabled": true,
      "steady_state": {
        "ocpu": 0.03,
        "memory_mib": 64,
        "disk_gib": 0.1
      },
      "hard_limit": {
        "ocpu": 0.1,
        "memory_mib": 256,
        "disk_gib": 0.2
      },
      "postgres_connections": 8,
      "queue": {
        "bounded": true,
        "capacity": 256,
        "overflow_behavior": "reject"
      },
      "retry": {
        "maximum_attempts": 0,
        "maximum_elapsed_seconds": 0,
        "backoff": "none",
        "jitter": false
      },
      "failure_behavior": "reject-new-work"
    }
  ]
}
