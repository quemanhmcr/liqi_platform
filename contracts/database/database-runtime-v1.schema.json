{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/database/database-runtime-v1.schema.json",
  "title": "LIQI Database Runtime V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "status",
    "authority",
    "requiredMigration",
    "compatibility",
    "repoSemantics",
    "roles",
    "connectionBudget",
    "transactionPolicy",
    "timeoutPolicy",
    "capacity",
    "migrationPolicy",
    "callableSeams",
    "consumerIntegration"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "contractVersion": {
      "const": "database-runtime-v1"
    },
    "status": {
      "enum": [
        "draft",
        "accepted"
      ]
    },
    "authority": {
      "const": "postgresql-only-durable-authority"
    },
    "requiredMigration": {
      "const": 8
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "postgresqlMajor",
        "ectoSql",
        "postgrex",
        "oban",
        "decimal",
        "pgbouncerMode",
        "v0ReadCompatibility"
      ],
      "properties": {
        "postgresqlMajor": {
          "const": 17
        },
        "ectoSql": {
          "pattern": "^>=3\\.14,<3\\.15$"
        },
        "postgrex": {
          "pattern": "^>=0\\.22\\.3,<0\\.23$"
        },
        "oban": {
          "pattern": "^>=2\\.23,<2\\.24$"
        },
        "pgbouncerMode": {
          "const": "transaction"
        },
        "v0ReadCompatibility": {
          "const": true
        },
        "decimal": {
          "pattern": "^>=3\\.0,<4\\.0$"
        }
      }
    },
    "repoSemantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prepare",
        "sessionState",
        "listenNotify",
        "migrationEndpoint",
        "runtimeEndpoint",
        "queryLogging",
        "telemetry"
      ],
      "properties": {
        "prepare": {
          "const": "unnamed"
        },
        "sessionState": {
          "const": "forbidden"
        },
        "listenNotify": {
          "const": "forbidden-through-runtime-pool"
        },
        "migrationEndpoint": {
          "const": "direct-postgresql"
        },
        "runtimeEndpoint": {
          "const": "pgbouncer"
        },
        "queryLogging": {
          "const": "disabled-by-provider"
        },
        "telemetry": {
          "const": "ecto-repo-events-enabled"
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "login",
          "superuser",
          "purpose"
        ],
        "properties": {
          "name": {
            "pattern": "^liqi_[a-z0-9_]+$"
          },
          "login": {
            "type": "boolean"
          },
          "superuser": {
            "const": false
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "connectionBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "postgresMaxConnections",
        "pgbouncerServerCapacity",
        "directReservation",
        "reservedHeadroom",
        "ectoPools",
        "poolRoleCaps"
      ],
      "properties": {
        "postgresMaxConnections": {
          "const": 80
        },
        "pgbouncerServerCapacity": {
          "const": 40
        },
        "directReservation": {
          "const": 10
        },
        "reservedHeadroom": {
          "const": 30
        },
        "ectoPools": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command",
            "realtime",
            "jobs"
          ],
          "properties": {
            "command": {
              "const": 12
            },
            "realtime": {
              "const": 4
            },
            "jobs": {
              "const": 6
            }
          }
        },
        "poolRoleCaps": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "liqi_api",
            "liqi_realtime",
            "liqi_worker"
          ],
          "properties": {
            "liqi_api": {
              "const": 20
            },
            "liqi_realtime": {
              "const": 5
            },
            "liqi_worker": {
              "const": 10
            }
          }
        }
      }
    },
    "transactionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultIsolation",
        "commandIsolation",
        "idempotencyLock",
        "aggregateVersion",
        "dualWrite"
      ],
      "properties": {
        "defaultIsolation": {
          "const": "read-committed"
        },
        "commandIsolation": {
          "const": "read-committed-with-row-and-transaction-advisory-locks"
        },
        "idempotencyLock": {
          "const": "pg_advisory_xact_lock"
        },
        "aggregateVersion": {
          "const": "expected-version-compare-and-increment"
        },
        "dualWrite": {
          "const": false
        }
      }
    },
    "timeoutPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commandStatementMs",
        "realtimeStatementMs",
        "workerStatementMs",
        "lockMs",
        "idleTransactionMs",
        "poolQueueTargetMs",
        "poolQueueIntervalMs"
      ],
      "properties": {
        "commandStatementMs": {
          "const": 5000
        },
        "realtimeStatementMs": {
          "const": 3000
        },
        "workerStatementMs": {
          "const": 30000
        },
        "lockMs": {
          "const": 2000
        },
        "idleTransactionMs": {
          "const": 15000
        },
        "poolQueueTargetMs": {
          "const": 50
        },
        "poolQueueIntervalMs": {
          "const": 1000
        }
      }
    },
    "capacity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "postgresMemoryMiB",
        "pgbouncerMemoryMiB",
        "backupTransientMemoryMiB",
        "hardMemoryMiB",
        "hardOcpu",
        "hardDiskGiB",
        "walMaxGiB",
        "outboxRetentionDays",
        "realtimeRetentionDays",
        "backupTransientDiskGiB"
      ],
      "properties": {
        "postgresMemoryMiB": {
          "const": 5632
        },
        "pgbouncerMemoryMiB": {
          "const": 128
        },
        "backupTransientMemoryMiB": {
          "const": 1536
        },
        "hardMemoryMiB": {
          "const": 7936
        },
        "hardOcpu": {
          "const": 1.2
        },
        "hardDiskGiB": {
          "const": 130.2
        },
        "walMaxGiB": {
          "const": 8
        },
        "outboxRetentionDays": {
          "const": 30
        },
        "realtimeRetentionDays": {
          "const": 7
        },
        "backupTransientDiskGiB": {
          "const": 32
        }
      }
    },
    "migrationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direction",
        "strategy",
        "downMigrations",
        "registry",
        "lock",
        "runtimeStartupMigration"
      ],
      "properties": {
        "direction": {
          "const": "forward-only"
        },
        "strategy": {
          "const": "expand-migrate-contract"
        },
        "downMigrations": {
          "const": false
        },
        "registry": {
          "const": "platform.schema_migrations"
        },
        "lock": {
          "const": "direct-session-advisory-lock"
        },
        "runtimeStartupMigration": {
          "const": false
        }
      }
    },
    "callableSeams": {
      "const": {
        "readiness": {
          "signature": "platform.database_readiness_v1(bigint,integer)",
          "roles": [
            "liqi_api",
            "liqi_realtime",
            "liqi_worker",
            "liqi_readonly",
            "liqi_monitor",
            "liqi_backup"
          ],
          "resultColumns": [
            "ready",
            "write_ready",
            "reason",
            "current_version",
            "expected_version",
            "oban_migration_version",
            "expected_oban_migration_version",
            "in_recovery"
          ]
        },
        "requestProbe": {
          "signature": "platform.request_probe_v1(uuid,uuid,text,text,text,bigint,timestamptz,uuid,uuid,jsonb,timestamptz,jsonb)",
          "roles": [
            "liqi_api"
          ],
          "resultColumns": [
            "probe_id",
            "event_id",
            "aggregate_version",
            "handoff_cursor",
            "duplicate",
            "status",
            "outcome"
          ],
          "errors": {
            "idempotencyConflict": "LQ001",
            "staleAggregateVersion": "LQ002"
          }
        },
        "observeProbe": {
          "signature": "platform.observe_probe_v1(uuid,uuid)",
          "roles": [
            "liqi_api",
            "liqi_readonly",
            "liqi_monitor",
            "liqi_backup"
          ],
          "resultColumns": [
            "probe_id",
            "event_id",
            "aggregate_version",
            "probe_status",
            "outbox_state",
            "effect_applied",
            "handoff_cursor",
            "terminal",
            "observed_at"
          ],
          "errors": {
            "notFound": "empty-result",
            "identityMismatch": "LQ003"
          }
        },
        "claimOutbox": {
          "signature": "platform.claim_outbox_v1(text,integer,integer)",
          "roles": [
            "liqi_worker"
          ],
          "resultColumns": [
            "event_id",
            "claim_token",
            "attempt_no",
            "protocol_version",
            "message_id",
            "correlation_id",
            "causation_id",
            "trace_context",
            "deadline_at",
            "actor_key",
            "aggregate_key",
            "priority",
            "payload_type",
            "event_type",
            "payload_version",
            "event_version",
            "ordering_key",
            "occurred_at",
            "producer",
            "payload",
            "metadata",
            "lease_expires_at"
          ]
        },
        "applyProbeEffect": {
          "signature": "platform.apply_probe_effect_and_ack_v1(uuid,uuid,text)",
          "roles": [
            "liqi_worker"
          ],
          "result": "status-text"
        },
        "failOutbox": {
          "signature": "platform.fail_outbox_v1(uuid,uuid,text,text,timestamptz)",
          "roles": [
            "liqi_worker"
          ],
          "result": "status-text"
        },
        "readHandoff": {
          "signature": "platform.read_realtime_handoff_v1(bigint,integer)",
          "roles": [
            "liqi_realtime"
          ],
          "resultColumns": [
            "handoff_id",
            "event_id",
            "protocol_version",
            "message_id",
            "correlation_id",
            "causation_id",
            "trace_context",
            "deadline_at",
            "actor_key",
            "aggregate_key",
            "priority",
            "payload_type",
            "event_type",
            "payload_version",
            "event_version",
            "ordering_key",
            "occurred_at",
            "producer",
            "payload",
            "metadata",
            "recorded_at"
          ],
          "errors": {
            "cursorGap": "LQ004"
          }
        }
      }
    },
    "consumerIntegration": {
      "const": {
        "module": "LiqiPersistence.RuntimeAdapter",
        "callbacks": [
          "readiness/1",
          "request_probe/1",
          "observe_probe/2",
          "claim_probe_events/2",
          "apply_probe_effect/3",
          "fail_event/5",
          "read_handoff/2"
        ],
        "repoOwnership": "runtime-configured-single-pool-set",
        "commandIdentity": "consumer-module-event_id/1",
        "providerStartupDefault": "disabled-until-runtime-owner-configures-supervision"
      }
    }
  }
}
