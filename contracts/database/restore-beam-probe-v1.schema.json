{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/database/restore-beam-probe-v1.schema.json",
  "title": "LIQI isolated restore BEAM read-only probe V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "git_sha", "release_id", "migration_version", "database_ready", "write_ready", "in_recovery", "probe_id", "event_id", "probe_status", "outbox_state", "effect_applied", "terminal", "status", "observed_at"],
  "properties": {
    "schema_version": {"const": "liqi.database.restore-beam-probe/v1"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "release_id": {"type": "string", "pattern": "^liqi-v1-[a-z0-9][a-z0-9._-]{2,95}$"},
    "migration_version": {"const": 8},
    "database_ready": {"const": true},
    "write_ready": {"const": true},
    "in_recovery": {"const": false},
    "probe_id": {"type": "string", "format": "uuid"},
    "event_id": {"type": "string", "format": "uuid"},
    "probe_status": {"const": "completed"},
    "outbox_state": {"const": "succeeded"},
    "effect_applied": {"const": true},
    "terminal": {"const": true},
    "status": {"const": "passed"},
    "observed_at": {"type": "string", "format": "date-time"}
  }
}
