{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/runtime/runtime-integration-result-v1.schema.json",
  "title": "LIQI BEAM disposable database integration V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "git_sha", "observed_at", "status", "database_target", "checks", "blockers"],
  "properties": {
    "schema_version": {"const": "runtime-integration-result-v1"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "observed_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["passed", "blocked", "failed"]},
    "database_target": {"const": "disposable-redacted"},
    "checks": {"type": "array", "items": {"type": "object", "required": ["name", "status"], "additionalProperties": false, "properties": {"name": {"type": "string"}, "status": {"enum": ["passed", "blocked", "failed"]}}}},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
