{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/native/native-safety-result-v1.schema.json",
  "title": "LIQI native safety gate result V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "git_sha",
    "status",
    "started_at",
    "completed_at",
    "toolchain",
    "checks",
    "fuzz_seconds",
    "property_cases",
    "failures"
  ],
  "properties": {
    "schema_version": {"const": "native-safety-result-v1"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "status": {"enum": ["passed", "blocked", "failed"]},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rust", "cargo", "elixir", "otp", "rustler", "nif_abi"],
      "properties": {
        "rust": {"type": "string", "minLength": 1, "maxLength": 128},
        "cargo": {"type": "string", "minLength": 1, "maxLength": 128},
        "elixir": {"type": "string", "minLength": 1, "maxLength": 128},
        "otp": {"type": "string", "minLength": 1, "maxLength": 128},
        "rustler": {"const": "0.38.0"},
        "nif_abi": {"const": "2.15"}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "command", "duration_ms", "log_ref"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
          "status": {"enum": ["passed", "blocked", "failed"]},
          "command": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1, "maxLength": 512}
          },
          "duration_ms": {"type": "integer", "minimum": 0, "maximum": 7200000},
          "log_ref": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+$", "maxLength": 512}
        }
      }
    },
    "fuzz_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "property_cases": {"const": 2000},
    "failures": {
      "type": "array",
      "maxItems": 32,
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "passed"}}, "required": ["status"]},
      "then": {
        "properties": {
          "failures": {"maxItems": 0},
          "checks": {"items": {"properties": {"status": {"const": "passed"}}}}
        }
      }
    }
  ]
}
