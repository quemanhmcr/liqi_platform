{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/native/native-artifact-v1.schema.json",
  "title": "LIQI native Linux GNU artifact V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact",
    "artifact_version",
    "release_id",
    "source_revision",
    "crate",
    "target_triple",
    "architecture",
    "libc",
    "rust_toolchain",
    "cargo_version",
    "rustler_version",
    "nif_abi",
    "build_profile",
    "panic_strategy",
    "artifact_path",
    "artifact_sha256",
    "artifact_size_bytes",
    "kernels",
    "sbom",
    "provenance",
    "signature",
    "built_at"
  ],
  "properties": {
    "schema_version": {
      "const": "native-artifact-v1"
    },
    "artifact": {
      "const": "liqi_sequence_diff_nif"
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "release_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "source_revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "crate": {
      "const": "liqi-sequence-diff-nif"
    },
    "target_triple": {
      "enum": [
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu"
      ]
    },
    "architecture": {
      "enum": [
        "aarch64",
        "x86_64"
      ]
    },
    "libc": {
      "const": "gnu"
    },
    "rust_toolchain": {
      "const": "1.97.1"
    },
    "cargo_version": {
      "const": "1.97.1"
    },
    "rustler_version": {
      "const": "0.38.0"
    },
    "nif_abi": {
      "const": "2.15"
    },
    "build_profile": {
      "const": "nif-release"
    },
    "panic_strategy": {
      "const": "unwind"
    },
    "artifact_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.).+\\.so$",
      "maxLength": 512
    },
    "artifact_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact_size_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 67108864
    },
    "kernels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version",
          "scheduler_class"
        ],
        "properties": {
          "name": {
            "const": "compact_sequence_diff"
          },
          "version": {
            "const": "1"
          },
          "scheduler_class": {
            "const": "regular"
          }
        }
      }
    },
    "sbom": {
      "$ref": "#/$defs/attestation"
    },
    "provenance": {
      "$ref": "#/$defs/attestation"
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "bundle_path",
        "bundle_sha256",
        "identity",
        "issuer"
      ],
      "properties": {
        "algorithm": {
          "const": "cosign-keyless"
        },
        "bundle_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.).+\\.sigstore\\.json$",
          "maxLength": 512
        },
        "bundle_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "identity": {
          "type": "string",
          "minLength": 3,
          "maxLength": 512
        },
        "issuer": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://",
          "maxLength": 512
        }
      }
    },
    "built_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "media_type"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.).+\\.json$",
          "maxLength": 512
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "media_type": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "target_triple": {
            "const": "aarch64-unknown-linux-gnu"
          }
        }
      },
      "then": {
        "properties": {
          "architecture": {
            "const": "aarch64"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_triple": {
            "const": "x86_64-unknown-linux-gnu"
          }
        }
      },
      "then": {
        "properties": {
          "architecture": {
            "const": "x86_64"
          }
        }
      }
    }
  ]
}
