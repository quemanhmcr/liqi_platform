{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liqi.example/contracts/infrastructure/secret-mapping-v1.schema.json",
  "title": "LIQI OCI Vault service credential mapping V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "service",
    "credentials"
  ],
  "properties": {
    "schema_version": {
      "const": "liqi.infrastructure.secret-mapping/v1"
    },
    "service": {
      "enum": [
        "beam",
        "liqi-api",
        "liqi-realtime",
        "liqi-worker",
        "database"
      ]
    },
    "credentials": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "secret_ocid",
          "stage"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "secret_ocid": {
            "type": "string",
            "pattern": "^ocid1\\.vaultsecret\\."
          },
          "stage": {
            "enum": [
              "CURRENT",
              "PENDING",
              "PREVIOUS"
            ]
          }
        }
      }
    }
  }
}
