{
  "schema_version": "liqi.infrastructure.oci-live/v1",
  "environment": "v1-live",
  "classification": "production-shaped-development",
  "git_sha": "0000000000000000000000000000000000000000",
  "infrastructure_output_version": "1.0.0",
  "region": {
    "name": "ap-singapore-2",
