{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liqi.example/contracts/infrastructure/database-credentials-v1.schema.json",
  "title": "LIQI database credential activation evidence V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "bundle_sha256",
    "roles",
    "runtime_bundle_path",
    "pgbouncer_userlist_path",
    "approval_reference",
    "observed_at",
    "database_mutation_performed"
  ],
  "properties": {
    "schema_version": {
      "const": "liqi.infrastructure.database-credentials/v1"
    },
    "status": {
      "enum": [
        "planned",
        "applied",
        "restored"
      ]
    },
    "bundle_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "roles": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": {
        "enum": [
          "liqi_migrator",
          "liqi_api",
          "liqi_realtime",
          "liqi_worker",
          "liqi_readonly",
          "liqi_monitor",
          "liqi_backup"
        ]
      }
    },
    "runtime_bundle_path": {
      "const": "/run/liqi/secrets/beam/database-role-urls"
    },
    "pgbouncer_userlist_path": {
      "const": "/run/liqi/secrets/database/pgbouncer-userlist.txt"
    },
    "approval_reference": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "database_mutation_performed": {
      "type": "boolean"
    }
  }
}
