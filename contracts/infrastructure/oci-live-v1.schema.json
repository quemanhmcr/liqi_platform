{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liqi.example/contracts/infrastructure/oci-live-v1.schema.json",
  "title": "LIQI OCI live environment V1 provider output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "environment",
    "classification",
    "git_sha",
    "infrastructure_output_version",
    "region",
    "capacity",
    "network",
    "host",
    "storage",
    "identity",
    "state_backend",
    "mutation"
  ],
  "properties": {
    "schema_version": {
      "const": "liqi.infrastructure.oci-live/v1"
    },
    "environment": {
      "const": "v1-live"
    },
    "classification": {
      "const": "production-shaped-development"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "infrastructure_output_version": {
      "const": "1.1.0"
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "availability_domain"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z]{2}-[a-z]+-[0-9]+$"
        },
        "availability_domain": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128
        }
      }
    },
    "capacity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shape",
        "architecture",
        "ocpus",
        "memory_gib",
        "boot_volume_gib",
        "data_volume_gib",
        "combined_storage_gib",
        "provider_cpu_ceiling",
        "provider_memory_ceiling_gib",
        "provider_disk_ceiling_gib",
        "host_reserve",
        "cost_classification"
      ],
      "properties": {
        "shape": {
          "const": "VM.Standard.A1.Flex"
        },
        "architecture": {
          "const": "aarch64"
        },
        "ocpus": {
          "const": 4
        },
        "memory_gib": {
          "const": 24
        },
        "boot_volume_gib": {
          "const": 50
        },
        "data_volume_gib": {
          "const": 130
        },
        "combined_storage_gib": {
          "const": 180
        },
        "provider_cpu_ceiling": {
          "const": 3
        },
        "provider_memory_ceiling_gib": {
          "const": 20
        },
        "provider_disk_ceiling_gib": {
          "const": 180
        },
        "host_reserve": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ocpus",
            "memory_gib",
            "disk_gib",
            "swap_is_capacity"
          ],
          "properties": {
            "ocpus": {
              "const": 1
            },
            "memory_gib": {
              "const": 4
            },
            "disk_gib": {
              "const": 20
            },
            "swap_is_capacity": {
              "const": false
            }
          }
        },
        "cost_classification": {
          "enum": [
            "always-free-eligible-capacity-not-guaranteed",
            "free-trial-only",
            "paid-approved",
            "unknown-blocked"
          ]
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vcn_id",
        "edge_subnet_id",
        "host_nsg_id",
        "public_ingress",
        "ssh_default_enabled",
        "loopback_services",
        "management_tunnel"
      ],
      "properties": {
        "vcn_id": {
          "type": "string",
          "pattern": "^ocid1\\.vcn\\."
        },
        "edge_subnet_id": {
          "type": "string",
          "pattern": "^ocid1\\.subnet\\."
        },
        "host_nsg_id": {
          "type": "string",
          "pattern": "^ocid1\\.networksecuritygroup\\."
        },
        "public_ingress": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "protocol",
              "port",
              "purpose"
            ],
            "properties": {
              "protocol": {
                "const": "tcp"
              },
              "port": {
                "enum": [
                  80,
                  443
                ]
              },
              "purpose": {
                "enum": [
                  "http-redirect-and-acme",
                  "https-edge"
                ]
              }
            }
          }
        },
        "ssh_default_enabled": {
          "const": false
        },
        "loopback_services": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "phoenix-http",
              "postgresql",
              "pgbouncer",
              "otlp-grpc",
              "otlp-http",
              "metrics"
            ]
          }
        },
        "management_tunnel": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "protocol",
            "peer_cidr",
            "peer_port",
            "public_ingress_required",
            "preflight_status"
          ],
          "properties": {
            "mode": {
              "const": "outbound-only"
            },
            "protocol": {
              "const": "wireguard-udp"
            },
            "peer_cidr": {
              "type": "string",
              "pattern": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}/32$"
            },
            "peer_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "public_ingress_required": {
              "const": false
            },
            "preflight_status": {
              "enum": [
                "pending-management-plane-preflight",
                "validated"
              ]
            }
          }
        }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instance_id",
        "image_id",
        "private_ipv4",
        "public_ipv4",
        "public_ip_mode",
        "legacy_imds_disabled",
        "run_command_plugin_enabled"
      ],
      "properties": {
        "instance_id": {
          "type": "string",
          "pattern": "^ocid1\\.instance\\."
        },
        "image_id": {
          "type": "string",
          "pattern": "^ocid1\\.image\\."
        },
        "private_ipv4": {
          "type": "string",
          "format": "ipv4"
        },
        "public_ipv4": {
          "type": "string",
          "format": "ipv4"
        },
        "public_ip_mode": {
          "enum": [
            "ephemeral",
            "reserved-approved"
          ]
        },
        "legacy_imds_disabled": {
          "const": true
        },
        "run_command_plugin_enabled": {
          "const": true
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_volume_id",
        "data_volume_preserved",
        "application_backup_authority",
        "artifact_archive_authority",
        "kms_key_id",
        "vault_id"
      ],
      "properties": {
        "data_volume_id": {
          "type": "string",
          "pattern": "^ocid1\\.volume\\."
        },
        "data_volume_preserved": {
          "const": true
        },
        "kms_key_id": {
          "type": "string",
          "pattern": "^ocid1\\.key\\."
        },
        "vault_id": {
          "type": "string",
          "pattern": "^ocid1\\.vault\\."
        },
        "application_backup_authority": {
          "const": "independent-management-storage"
        },
        "artifact_archive_authority": {
          "const": "independent-management-storage"
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dynamic_group_id",
        "instance_principal",
        "capabilities",
        "user_api_keys_present"
      ],
      "properties": {
        "dynamic_group_id": {
          "type": "string",
          "pattern": "^ocid1\\.dynamicgroup\\."
        },
        "instance_principal": {
          "const": true
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "vault-secret-bundle-read"
            ]
          },
          "maxItems": 1
        },
        "user_api_keys_present": {
          "const": false
        }
      }
    },
    "state_backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "remote",
        "versioned",
        "locking",
        "credentials_in_source",
        "compatibility_status"
      ],
      "properties": {
        "kind": {
          "const": "postgresql-self-hosted"
        },
        "remote": {
          "const": true
        },
        "versioned": {
          "const": false
        },
        "locking": {
          "const": "postgresql-advisory-locks"
        },
        "credentials_in_source": {
          "const": false
        },
        "compatibility_status": {
          "enum": [
            "pending-state-backend-evidence",
            "validated"
          ]
        }
      }
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_required",
        "applied",
        "approval_reference",
        "plan_sha256"
      ],
      "properties": {
        "approval_required": {
          "const": true
        },
        "applied": {
          "type": "boolean"
        },
        "approval_reference": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        },
        "plan_sha256": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
