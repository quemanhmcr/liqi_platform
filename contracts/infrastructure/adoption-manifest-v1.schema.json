{
  "$id": "https://liqi.example/contracts/infrastructure/adoption-manifest-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blockers": {
      "items": {
        "maxLength": 512,
        "minLength": 3,
        "type": "string"
      },
      "type": "array"
    },
    "capacity_profile": {
      "const": "e5-temporary"
    },
    "compartment_name": {
      "maxLength": 95,
      "minLength": 3,
      "type": "string"
    },
    "discovered_at": {
      "format": "date-time",
      "type": "string"
    },
    "git_sha": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "imports": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "address": {
            "pattern": "^module\\.v1_live\\.[A-Za-z0-9_\\[\\].\"/:-]+$",
            "type": "string"
          },
          "display_name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string"
          },
          "id": {
            "anyOf": [
              {
                "pattern": "^ocid1\\.",
                "type": "string"
              },
              {
                "pattern": "^networkSecurityGroups/ocid1\\.networksecuritygroup\\.[A-Za-z0-9._-]+/securityRules/[A-Za-z0-9._-]+$",
                "type": "string"
              },
              {
                "pattern": "^managementEndpoint/https://[A-Za-z0-9.-]+/keys/ocid1\\.key\\.[A-Za-z0-9._-]+$",
                "type": "string"
              },
              {
                "pattern": "^networkLoadBalancers/ocid1\\.networkloadbalancer\\.[A-Za-z0-9._-]+/(?:backendSets/[A-Za-z0-9._-]+(?:/backends/[A-Za-z0-9._:-]+)?|listeners/[A-Za-z0-9._-]+)$",
                "type": "string"
              }
            ]
          },
          "resource_type": {
            "pattern": "^oci_",
            "type": "string"
          }
        },
        "required": [
          "address",
          "id",
          "resource_type",
          "display_name"
        ],
        "type": "object"
      },
      "maxItems": 64,
      "type": "array"
    },
    "missing_addresses": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "oci_mutation_performed": {
      "const": false
    },
    "region": {
      "const": "ap-singapore-2"
    },
    "schema_version": {
      "const": "liqi.infrastructure.adoption-manifest/v1"
    },
    "status": {
      "enum": [
        "passed",
        "blocked"
      ]
    },
    "unmanaged_resources": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "display_name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "reason": {
            "maxLength": 512,
            "minLength": 3,
            "type": "string"
          }
        },
        "required": [
          "kind",
          "display_name",
          "reason"
        ],
        "type": "object"
      },
      "maxItems": 64,
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "git_sha",
    "capacity_profile",
    "region",
    "compartment_name",
    "discovered_at",
    "status",
    "imports",
    "missing_addresses",
    "unmanaged_resources",
    "blockers",
    "oci_mutation_performed"
  ],
  "title": "LIQI V1 OCI adoption manifest",
  "type": "object"
}
