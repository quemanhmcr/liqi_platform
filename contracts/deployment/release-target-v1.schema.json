{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liqi.example/contracts/deployment/release-target-v1.schema.json",
  "title": "LIQI host-local release activation descriptor V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "runtime_generation",
    "git_sha",
    "release_path",
    "source_manifest",
    "services",
    "drain",
    "health",
    "database_compatibility",
    "rollback_target_release_id",
    "configuration_paths",
    "created_at",
    "database_compatibility_evidence",
    "runtime_config_path",
    "credential_directory",
    "required_credentials"
  ],
  "properties": {
    "schema_version": {
      "const": "liqi.deployment.release-target/v1"
    },
    "release_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "runtime_generation": {
      "enum": [
        "rust-v0",
        "beam-v1"
      ]
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "release_path": {
      "type": "string",
      "pattern": "^/opt/liqi/releases/[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "source_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "sha256",
        "retained_path"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "retained_path": {
          "type": "string",
          "pattern": "^/var/lib/liqi/recovery/release-inputs/"
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "unit",
          "start_order",
          "stop_timeout_seconds"
        ],
        "properties": {
          "unit": {
            "type": "string",
            "pattern": "^liqi-[a-z0-9-]+\\.service$"
          },
          "start_order": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8
          },
          "stop_timeout_seconds": {
            "type": "integer",
            "minimum": 5,
            "maximum": 300
          }
        }
      }
    },
    "drain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "timeout_seconds"
      ],
      "properties": {
        "argv": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "maxItems": 32
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "timeout_seconds"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "maxItems": 32
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        }
      }
    },
    "database_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_migration",
        "maximum_migration",
        "rollback_safe_through",
        "database_rollback_allowed"
      ],
      "properties": {
        "minimum_migration": {
          "type": "integer",
          "minimum": 0
        },
        "maximum_migration": {
          "type": "integer",
          "minimum": 0
        },
        "rollback_safe_through": {
          "type": "integer",
          "minimum": 0
        },
        "database_rollback_allowed": {
          "const": false
        }
      }
    },
    "rollback_target_release_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "configuration_paths": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^/(etc|run)/liqi/"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "database_compatibility_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "sha256",
        "retained_path"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "retained_path": {
          "type": "string",
          "pattern": "^/var/lib/liqi/recovery/release-inputs/"
        }
      }
    },
    "runtime_config_path": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^/etc/liqi/runtime/releases/[a-z0-9][a-z0-9._-]{2,95}\\.json$"
    },
    "credential_directory": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^/run/liqi/secrets/[a-z0-9-]+$"
    },
    "required_credentials": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]{1,63}$"
      }
    }
  }
}
