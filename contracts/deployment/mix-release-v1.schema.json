{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liqi.example/contracts/deployment/mix-release-v1.schema.json",
  "title": "LIQI Mix release install handoff V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "release_name",
    "version",
    "git_sha",
    "target_triple",
    "manifest_signature",
    "artifact",
    "runtime",
    "configuration",
    "database_compatibility",
    "native_artifacts",
    "rollback_target_release_id",
    "installation",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "liqi.deployment.mix-release/v1"
    },
    "release_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "release_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "target_triple": {
      "enum": [
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filename",
        "size_bytes",
        "sha256",
        "signature"
      ],
      "properties": {
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}\\.tar\\.gz$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1073741824
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "key_id",
            "signature_filename",
            "signature_sha256",
            "signed_payload"
          ],
          "properties": {
            "algorithm": {
              "const": "ed25519"
            },
            "key_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
            },
            "signature_filename": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
            },
            "signature_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "signed_payload": {
              "const": "artifact-bytes"
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "otp_release",
        "elixir_version",
        "erts_included",
        "commands",
        "health_timeout_seconds",
        "drain_timeout_seconds"
      ],
      "properties": {
        "otp_release": {
          "type": "string",
          "pattern": "^[0-9]{2,3}(?:\\.[0-9]+){0,2}$"
        },
        "elixir_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "erts_included": {
          "const": true
        },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "stop",
            "drain",
            "health"
          ],
          "properties": {
            "start": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              }
            },
            "stop": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              }
            },
            "drain": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              }
            },
            "health": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              }
            }
          }
        },
        "health_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "drain_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_directory",
        "secret_reference_directory",
        "plaintext_secrets_forbidden"
      ],
      "properties": {
        "runtime_directory": {
          "const": "/etc/liqi/runtime"
        },
        "secret_reference_directory": {
          "const": "/etc/liqi/secrets"
        },
        "plaintext_secrets_forbidden": {
          "const": true
        }
      }
    },
    "database_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_migration",
        "maximum_migration",
        "rollback_safe_through"
      ],
      "properties": {
        "minimum_migration": {
          "type": "integer",
          "minimum": 0
        },
        "maximum_migration": {
          "type": "integer",
          "minimum": 0
        },
        "rollback_safe_through": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "native_artifacts": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "manifest_filename",
          "manifest_sha256",
          "required"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
          },
          "manifest_filename": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}\\.json$"
          },
          "manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "installation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_directory",
        "current_symlink",
        "immutable_after_install",
        "build_on_host"
      ],
      "properties": {
        "release_directory": {
          "type": "string",
          "pattern": "^/opt/liqi/releases/[a-z0-9][a-z0-9._-]{2,95}$"
        },
        "current_symlink": {
          "const": "/opt/liqi/current"
        },
        "immutable_after_install": {
          "const": true
        },
        "build_on_host": {
          "const": false
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "manifest_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "signature_filename",
        "signed_payload"
      ],
      "properties": {
        "algorithm": {
          "const": "ed25519"
        },
        "key_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
        },
        "signature_filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}\\.json\\.sig$"
        },
        "signed_payload": {
          "const": "exact-manifest-bytes"
        }
      }
    },
    "rollback_target_release_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
    }
  }
}
