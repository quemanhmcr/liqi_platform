{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liqi.example/contracts/deployment/mix-deployment-v1.schema.json",
  "title": "LIQI signed Mix deployment wrapper V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "git_sha",
    "provider_manifest",
    "runtime_artifact_result",
    "runtime_config",
    "database_contract",
    "migration_readiness",
    "native_artifacts",
    "rollback_target",
    "signature",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "liqi.deployment.mix-deployment/v1"
    },
    "release_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "provider_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "filename",
        "sha256"
      ],
      "properties": {
        "schema_version": {
          "const": "liqi.deployment.mix-release/v1"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "runtime_artifact_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "filename",
        "sha256"
      ],
      "properties": {
        "schema_version": {
          "const": "runtime-artifact-result-v1"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "runtime_config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "filename",
        "sha256"
      ],
      "properties": {
        "schema_version": {
          "const": "1"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "database_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "filename",
        "sha256"
      ],
      "properties": {
        "schema_version": {
          "const": "database-runtime-v1"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "migration_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "filename",
        "sha256"
      ],
      "properties": {
        "schema_version": {
          "const": "migration-readiness-v1"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "native_artifacts": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "provider_manifest_filename",
          "provider_manifest_sha256",
          "deployment_manifest_filename",
          "deployment_manifest_sha256",
          "install_relative_path",
          "required"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
          },
          "provider_manifest_filename": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
          },
          "provider_manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "deployment_manifest_filename": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
          },
          "deployment_manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "install_relative_path": {
            "type": "string",
            "pattern": "^lib/[A-Za-z0-9_./-]+\\.so$"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "rollback_target": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "release_id",
        "descriptor_filename",
        "descriptor_sha256"
      ],
      "properties": {
        "release_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
        },
        "descriptor_filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.json$"
        },
        "descriptor_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "signature_filename",
        "signed_payload"
      ],
      "properties": {
        "algorithm": {
          "const": "ed25519"
        },
        "key_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
        },
        "signature_filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}\\.sig$"
        },
        "signed_payload": {
          "const": "exact-wrapper-bytes"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
