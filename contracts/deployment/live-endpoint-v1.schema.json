{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liqi.example/contracts/deployment/live-endpoint-v1.schema.json",
  "title": "LIQI V1 live endpoint evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "environment",
    "classification",
    "git_sha",
    "release_id",
    "hostname",
    "public_ports",
    "tls",
    "backend",
    "websocket",
    "health",
    "security",
    "status",
    "observed_at",
    "evidence_class"
  ],
  "properties": {
    "schema_version": {
      "const": "liqi.deployment.live-endpoint/v1"
    },
    "environment": {
      "const": "v1-live"
    },
    "classification": {
      "const": "production-shaped-development"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "release_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "hostname": {
      "type": "string",
      "format": "hostname"
    },
    "public_ports": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": [
          80,
          443
        ]
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "issuer",
        "certificate_status",
        "renewal_command"
      ],
      "properties": {
        "mode": {
          "enum": [
            "public-acme",
            "operator-provided"
          ]
        },
        "issuer": {
          "type": "string",
          "maxLength": 128
        },
        "certificate_status": {
          "enum": [
            "valid",
            "pending",
            "failed"
          ]
        },
        "renewal_command": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "address",
        "publicly_routable"
      ],
      "properties": {
        "address": {
          "const": "127.0.0.1:4000"
        },
        "publicly_routable": {
          "const": false
        }
      }
    },
    "websocket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "supported",
        "resume_evidence"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "supported": {
          "type": "boolean"
        },
        "resume_evidence": {
          "enum": [
            "passed",
            "failed",
            "pending"
          ]
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_path",
        "public_detail_level",
        "internal_path"
      ],
      "properties": {
        "public_path": {
          "const": "/health/live"
        },
        "public_detail_level": {
          "const": "binary-no-dependency-detail"
        },
        "internal_path": {
          "const": "/health/ready"
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "admin_api_public",
        "http_redirect",
        "request_body_limit_bytes",
        "header_limit_bytes",
        "security_headers"
      ],
      "properties": {
        "admin_api_public": {
          "const": false
        },
        "http_redirect": {
          "const": true
        },
        "request_body_limit_bytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 10485760
        },
        "header_limit_bytes": {
          "type": "integer",
          "minimum": 4096,
          "maximum": 131072
        },
        "security_headers": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "enum": [
        "verified",
        "failed",
        "engineering-complete-evidence-pending"
      ]
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_class": {
      "enum": [
        "source-only",
        "live-approved"
      ]
    }
  }
}
