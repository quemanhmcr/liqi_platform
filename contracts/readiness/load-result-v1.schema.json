  "properties": {
    "schema_version": {
      "const": "load-result-v1"
    },
    "evidence_mode": {
      "enum": [
        "live",
        "synthetic"
      ]
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "release_id": {
      "type": "string",
      "pattern": "^liqi-v1-[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "environment": {
      "enum": [
        "staging",
        "production"
      ]
    },
    "profile": {
      "enum": [
        "floor",
        "stretch",
        "diagnostic"
      ]
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shape",
        "ocpu",
        "memory_mib",
        "combined_storage_gib"
      ],
      "properties": {
        "shape": {
          "const": "VM.Standard.A1.Flex"
        },
        "ocpu": {
          "const": 4
        },
        "memory_mib": {
          "const": 24576
        },
        "combined_storage_gib": {
          "type": "number",
          "maximum": 200
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "seed",
        "records"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "revision": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "records": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "version",
        "source_sha256"
      ],
      "properties": {
        "tool": {
          "const": "k6"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "passed",
        "blocked",
        "failed"
      ]
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "concurrent_websocket_sessions",
        "active_subscriptions",
        "durable_commands_per_second",
        "realtime_events_per_second",
        "reconnect_fraction",
        "reconnect_window_seconds",
        "steady_duration_seconds",
        "arrival_pattern"
      ],
