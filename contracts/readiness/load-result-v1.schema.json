{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/readiness/load-result-v1.schema.json",
  "title": "LIQI load result V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_mode",
    "git_sha",
    "release_id",
    "environment",
    "profile",
    "host",
    "dataset",
    "generator",
    "started_at",
    "completed_at",
    "status",
    "workload",
    "latency",
    "resources",
    "outcomes",
    "recovery_after_load",
    "evidence_refs",
    "failures"
