{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/readiness/oci-mutation-log-v1.schema.json",
  "title": "LIQI approved OCI and live mutation log V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "git_sha",
    "release_id",
    "environment",
    "observed_at",
    "status",
    "mutations",
    "failures"
  ],
  "properties": {
    "schema_version": {"const": "oci-mutation-log-v1"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "release_id": {"type": "string", "pattern": "^liqi-v1-[a-z0-9][a-z0-9._-]{2,95}$"},
    "environment": {"const": "production"},
    "observed_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["passed", "blocked", "failed"]},
    "mutations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "approved", "approval_ref", "executed_by", "started_at", "completed_at", "evidence_ref"],
        "properties": {
          "kind": {"enum": ["tofu-apply", "oci-resource-change", "iam-policy", "secret", "live-deploy", "live-migration", "backup", "restore", "traffic", "rollback"]},
          "approved": {"type": "boolean"},
          "approval_ref": {"type": ["string", "null"], "maxLength": 512},
          "executed_by": {"const": "Senior 4"},
          "started_at": {"type": "string", "format": "date-time"},
          "completed_at": {"type": "string", "format": "date-time"},
          "evidence_ref": {"type": "string", "minLength": 1, "maxLength": 1024}
        }
      }
    },
    "failures": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "passed"}}, "required": ["status"]},
      "then": {
        "properties": {
          "mutations": {
            "items": {
              "properties": {
                "approved": {"const": true},
                "approval_ref": {"type": "string", "minLength": 1}
              },
              "required": ["approved", "approval_ref"]
            }
          },
          "failures": {"maxItems": 0}
        }
      }
    }
  ]
}
