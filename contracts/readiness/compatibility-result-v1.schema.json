{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/readiness/compatibility-result-v1.schema.json",
  "title": "LIQI V0/V1 compatibility result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "git_sha",
    "release_id",
    "observed_at",
    "status",
    "checks",
    "failures"
  ],
  "properties": {
    "schema_version": {
      "const": "compatibility-result-v1"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "release_id": {
      "type": "string",
      "pattern": "^liqi-v1-[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "passed",
        "blocked",
        "failed"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "owner",
          "status",
          "evidence_ref"
        ],
        "properties": {
          "name": {
            "enum": [
              "migrations-expand-compatible",
              "realtime-protocol-negotiated",
              "native-fallback-available",
              "config-versioned"
            ]
          },
          "owner": {
            "enum": [
              "Senior 1",
              "Senior 2",
              "Senior 3",
              "Senior 4"
            ]
          },
          "status": {
            "enum": [
              "passed",
              "blocked",
              "failed"
            ]
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        }
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    }
  }
}
