{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/readiness/checkpoint-result-v1.schema.json",
  "title": "LIQI V1 readiness checkpoint result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "git_sha",
    "release_id",
    "observed_at",
    "status",
    "provider_results",
    "evidence_refs",
    "blockers"
  ],
  "properties": {
    "schema_version": {
      "const": "checkpoint-result-v1"
    },
    "name": {
      "enum": [
        "source",
        "integration",
        "artifact",
        "live-staging",
        "promotion",
        "cutover",
        "post-cutover"
      ]
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "release_id": {
      "type": "string",
      "pattern": "^liqi-v1-[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "passed",
        "blocked",
        "failed"
      ]
    },
    "provider_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "owner",
          "seam",
          "status",
          "evidence_ref"
        ],
        "properties": {
          "owner": {
            "enum": [
              "Senior 1",
              "Senior 2",
              "Senior 3",
              "Senior 4",
              "Senior 5"
            ]
          },
          "seam": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "status": {
            "enum": [
              "passed",
              "blocked",
              "failed"
            ]
          },
          "evidence_ref": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 1024
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "owner",
          "seam",
          "code",
          "severity",
          "message",
          "action_required"
        ],
        "properties": {
          "owner": {
            "enum": [
              "Senior 1",
              "Senior 2",
              "Senior 3",
              "Senior 4",
              "Senior 5"
            ]
          },
          "seam": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "code": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]{2,63}$"
          },
          "severity": {
            "enum": [
              "blocked",
              "failed"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "action_required": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "provider_results": {
            "items": {
              "properties": {
                "status": {
                  "const": "passed"
                }
              },
              "required": [
                "status"
              ]
            }
          },
          "blockers": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "not": {
          "properties": {
            "status": {
              "const": "passed"
            }
          },
          "required": [
            "status"
          ]
        }
      },
      "then": {
        "properties": {
          "blockers": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
