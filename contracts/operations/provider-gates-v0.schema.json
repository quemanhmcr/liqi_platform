{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/operations/provider-gates-v0.schema.json",
  "title": "LIQI provider invocation registry V0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_version", "gates"],
  "properties": {
    "schema_version": {"const": "provider-gates-v0"},
    "registry_version": {"type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$"},
    "gates": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/gate"}
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "owner", "seam", "stages", "provider_state", "mutation_class",
        "required_paths", "argv", "timeout_seconds", "result_mode", "failure_class",
        "action_required"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
        "owner": {"enum": ["Senior 1", "Senior 2", "Senior 3"]},
        "seam": {"type": "string", "minLength": 1, "maxLength": 256},
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["source", "integration", "promotion"]},
          "uniqueItems": true
        },
        "provider_state": {"enum": ["available", "pending-provider", "pending-owner-build", "deprecated"]},
        "mutation_class": {"enum": ["read-only", "disposable-database", "host-mutation", "oci-mutation"]},
        "required_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+$"},
          "uniqueItems": true
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1, "maxLength": 512}
        },
        "required_environment": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,63}$"},
          "uniqueItems": true,
          "default": []
        },
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 1800},
        "result_mode": {"enum": ["exit-code", "json-file", "stdout-json"]},
        "failure_class": {"enum": ["contract", "configuration", "security", "capacity", "dependency", "runtime", "recovery"]},
        "action_required": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    }
  }
}
