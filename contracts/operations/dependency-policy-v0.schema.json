{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/operations/dependency-policy-v0.schema.json",
  "title": "LIQI dependency and license policy V0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "vulnerability", "licenses", "sources", "exceptions"],
  "properties": {
    "schema_version": {"const": "dependency-policy-v0"},
    "vulnerability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deny_severities", "yanked", "unmaintained", "unsound", "exceptions_require_expiry"],
      "properties": {
        "deny_severities": {
          "type": "array",
          "minItems": 2,
          "items": {"enum": ["low", "moderate", "high", "critical"]},
          "uniqueItems": true
        },
        "yanked": {"const": "deny"},
        "unmaintained": {"enum": ["deny", "warn"]},
        "unsound": {"const": "deny"},
        "exceptions_require_expiry": {"const": true}
      }
    },
    "licenses": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow", "deny", "unknown", "unlicensed", "confidence_threshold"],
      "properties": {
        "allow": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}, "uniqueItems": true},
        "deny": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}, "uniqueItems": true},
        "unknown": {"const": "deny"},
        "unlicensed": {"const": "deny"},
        "confidence_threshold": {"type": "number", "minimum": 0.8, "maximum": 1.0}
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unknown_registry", "unknown_git", "git_requires_full_revision", "allowed_registries"],
      "properties": {
        "unknown_registry": {"const": "deny"},
        "unknown_git": {"const": "deny"},
        "git_requires_full_revision": {"const": true},
        "allowed_registries": {"type": "array", "minItems": 1, "items": {"type": "string", "format": "uri"}, "uniqueItems": true}
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package", "reason", "owner", "expires_at", "decision_note"],
        "properties": {
          "package": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 12},
          "owner": {"enum": ["Senior 3", "Senior 4", "Project Owner"]},
          "expires_at": {"type": "string", "format": "date"},
          "decision_note": {"type": "string", "pattern": "^docs/adr/04[0-9]{2}-.+\\.md$"}
        }
      }
    }
  }
}
