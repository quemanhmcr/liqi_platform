{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/operations/telemetry-v0.schema.json",
  "title": "LIQI Platform telemetry capability declaration V0",
  "description": "Declares the signals a provider emits. It is validated before integration and carries no telemetry payload or private data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "service",
    "resource_attributes",
    "health",
    "structured_logs",
    "metrics",
    "traces",
    "cardinality_policy",
    "redaction_policy"
  ],
  "properties": {
    "schema_version": { "const": "telemetry-v0" },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "name", "owner"],
      "properties": {
        "namespace": { "const": "liqi-platform" },
        "name": {
          "type": "string",
          "enum": ["liqi-api", "liqi-realtime", "liqi-worker", "liqi-host", "liqi-database", "liqi-recovery"]
        },
        "owner": { "type": "string", "enum": ["Senior 1", "Senior 2", "Senior 3", "Senior 4"] }
      }
    },
    "resource_attributes": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": { "$ref": "#/$defs/attributeName" },
      "allOf": [
        { "contains": { "const": "service.namespace" } },
        { "contains": { "const": "service.name" } },
        { "contains": { "const": "service.version" } },
        { "contains": { "const": "deployment.environment.name" } },
        { "contains": { "const": "liqi.release.id" } }
      ]
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["liveness", "readiness", "platform_probe", "shutdown_deadline_seconds"],
      "properties": {
        "liveness": { "$ref": "#/$defs/healthEndpoint" },
        "readiness": { "$ref": "#/$defs/healthEndpoint" },
        "platform_probe": { "$ref": "#/$defs/healthEndpoint" },
        "shutdown_deadline_seconds": { "type": "integer", "minimum": 1, "maximum": 120 }
      }
    },
    "structured_logs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "required_fields", "maximum_event_bytes"],
      "properties": {
        "format": { "const": "json-lines" },
        "required_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/attributeName" },
          "allOf": [
            { "contains": { "const": "timestamp" } },
            { "contains": { "const": "severity" } },
            { "contains": { "const": "service.name" } },
            { "contains": { "const": "liqi.release.id" } },
            { "contains": { "const": "trace_id" } },
            { "contains": { "const": "request_id" } },
            { "contains": { "const": "operation" } },
            { "contains": { "const": "result.class" } },
            { "contains": { "const": "error.class" } }
          ]
        },
        "maximum_event_bytes": { "type": "integer", "minimum": 512, "maximum": 65536 }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/metric" }
    },
    "traces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["propagation", "required_span_attributes", "sampling"],
      "properties": {
        "propagation": { "const": "w3c-trace-context" },
        "required_span_attributes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/attributeName" },
          "allOf": [
            { "contains": { "const": "service.name" } },
            { "contains": { "const": "liqi.release.id" } },
            { "contains": { "const": "operation" } },
            { "contains": { "const": "result.class" } }
          ]
        },
        "sampling": {
          "type": "object",
          "additionalProperties": false,
          "required": ["strategy", "maximum_ratio"],
          "properties": {
            "strategy": { "type": "string", "enum": ["parent-based-ratio", "always-on-development"] },
            "maximum_ratio": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "cardinality_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_route_values", "forbidden_labels"],
      "properties": {
        "maximum_route_values": { "type": "integer", "minimum": 1, "maximum": 500 },
        "forbidden_labels": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 8,
          "items": { "$ref": "#/$defs/attributeName" },
          "allOf": [
            { "contains": { "const": "user.id" } },
            { "contains": { "const": "player.id" } },
            { "contains": { "const": "conversation.id" } },
            { "contains": { "const": "session.id" } },
            { "contains": { "const": "request_id" } },
            { "contains": { "const": "trace_id" } },
            { "contains": { "const": "email" } },
            { "contains": { "const": "ip.address" } }
          ]
        }
      }
    },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deny_fields", "replacement"],
      "properties": {
        "deny_fields": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 8,
          "items": { "$ref": "#/$defs/attributeName" },
          "allOf": [
            { "contains": { "const": "authorization" } },
            { "contains": { "const": "cookie" } },
            { "contains": { "const": "password" } },
            { "contains": { "const": "token" } },
            { "contains": { "const": "secret" } },
            { "contains": { "const": "private_key" } },
            { "contains": { "const": "message.body" } },
            { "contains": { "const": "media.signed_url" } }
          ]
        },
        "replacement": { "const": "[REDACTED]" }
      }
    }
  },
  "$defs": {
    "attributeName": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_.-]{0,127}$"
    },
    "healthEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "success_status", "timeout_ms"],
      "properties": {
        "path": { "type": "string", "pattern": "^/[-a-zA-Z0-9_/]*$" },
        "success_status": { "type": "integer", "minimum": 200, "maximum": 299 },
        "timeout_ms": { "type": "integer", "minimum": 50, "maximum": 5000 }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "instrument", "unit", "labels", "owner", "required"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_.]{2,127}$" },
        "instrument": {
          "type": "string",
          "enum": ["counter", "up-down-counter", "gauge", "histogram"]
        },
        "unit": { "type": "string", "minLength": 1, "maxLength": 32 },
        "labels": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/attributeName" }
        },
        "owner": { "type": "string", "enum": ["Senior 1", "Senior 2", "Senior 3", "Senior 4"] },
        "required": { "type": "boolean" },
        "explicit_bucket_boundaries": {
          "type": "array",
          "minItems": 2,
          "maxItems": 32,
          "items": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
