{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/operations/integration-result-v0.schema.json",
  "title": "LIQI Platform integration gate result V0",
  "description": "Machine-readable evidence for provider and integration gates. Secret-bearing stdout/stderr must be stored only after redaction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "integration_id",
    "release_id",
    "git_sha",
    "environment",
    "mode",
    "started_at",
    "completed_at",
    "overall_status",
    "provider_results",
    "gates",
    "capacity",
    "recovery",
    "platform_probe",
    "violations"
  ],
  "properties": {
    "schema_version": {
      "const": "integration-result-v0"
    },
    "integration_id": {
      "type": "string",
      "pattern": "^int-[a-z0-9._-]{6,96}$"
    },
    "release_id": {
      "type": "string",
      "pattern": "^liqi-[a-z0-9][a-z0-9._-]{2,95}$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "environment": {
      "type": "string",
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "mock",
        "provider"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked"
      ]
    },
    "provider_results": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/checkResult"
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/checkResult"
      }
    },
    "capacity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "hard_limit_ocpu",
        "hard_limit_memory_mib",
        "reserved_ocpu",
        "reserved_memory_mib",
        "declared_ocpu",
        "declared_memory_mib",
        "steady_state_ocpu",
        "steady_state_memory_mib",
        "disk_budget_gib"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "blocked"
          ]
        },
        "hard_limit_ocpu": {
          "const": 3
        },
        "hard_limit_memory_mib": {
          "const": 20480
        },
        "reserved_ocpu": {
          "type": "number",
          "minimum": 1
        },
        "reserved_memory_mib": {
          "type": "integer",
          "minimum": 4096
        },
        "declared_ocpu": {
          "type": "number",
          "minimum": 0,
          "maximum": 4
        },
        "declared_memory_mib": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20480
        },
        "steady_state_ocpu": {
          "type": "number",
          "minimum": 0,
          "maximum": 3
        },
        "steady_state_memory_mib": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20480
        },
        "disk_budget_gib": {
          "type": "number",
          "minimum": 0,
          "maximum": 200
        }
      }
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "backup_age_seconds",
        "wal_archive_lag_seconds",
        "restore_verified_at",
        "evidence_ref"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "blocked",
            "not-applicable"
          ]
        },
        "backup_age_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "wal_archive_lag_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "restore_verified_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "evidence_ref": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1024
        }
      }
    },
    "platform_probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "result_ref",
        "release_id_observed"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "blocked",
            "not-run"
          ]
        },
        "result_ref": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1024
        },
        "release_id_observed": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 96
        }
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/violation"
      }
    }
  },
  "$defs": {
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "seam",
        "command",
        "status",
        "exit_code",
        "duration_ms",
        "output_ref",
        "failure_class"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "owner": {
          "type": "string",
          "enum": [
            "Senior 1",
            "Senior 2",
            "Senior 3",
            "Senior 4"
          ]
        },
        "seam": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "blocked",
            "skipped"
          ]
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 255
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "output_ref": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1024
        },
        "failure_class": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "contract",
            "configuration",
            "security",
            "capacity",
            "dependency",
            "runtime",
            "recovery",
            "unknown"
          ]
        }
      }
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "seam",
        "code",
        "message",
        "action_required"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "owner": {
          "type": "string",
          "enum": [
            "Senior 1",
            "Senior 2",
            "Senior 3",
            "Senior 4"
          ]
        },
        "seam": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "action_required": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
