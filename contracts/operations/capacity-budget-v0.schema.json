{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/operations/capacity-budget-v0.schema.json",
  "title": "LIQI Platform provider capacity budget V0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provider", "owner", "components"],
  "properties": {
    "schema_version": { "const": "capacity-budget-v0" },
    "provider": { "type": "string", "enum": ["infrastructure", "database", "runtime", "operations"] },
    "owner": { "type": "string", "enum": ["Senior 1", "Senior 2", "Senior 3", "Senior 4"] },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "class",
        "default_enabled",
        "steady_state",
        "hard_limit",
        "postgres_connections",
        "queue",
        "retry",
        "failure_behavior"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
        "class": {
          "type": "string",
          "enum": ["host", "database", "pooler", "api", "realtime", "worker", "edge", "telemetry", "recovery"]
        },
        "default_enabled": { "type": "boolean" },
        "steady_state": { "$ref": "#/$defs/resources" },
        "hard_limit": { "$ref": "#/$defs/resources" },
        "postgres_connections": { "type": "integer", "minimum": 0, "maximum": 100 },
        "per_connection_memory_kib": { "type": "integer", "minimum": 1, "maximum": 1024 },
        "queue": {
          "type": "object",
          "additionalProperties": false,
          "required": ["bounded", "capacity", "overflow_behavior"],
          "properties": {
            "bounded": { "const": true },
            "capacity": { "type": "integer", "minimum": 0, "maximum": 1000000 },
            "overflow_behavior": {
              "type": "string",
              "enum": ["reject", "drop-noncritical", "persist-authoritatively", "not-applicable"]
            }
          }
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maximum_attempts", "maximum_elapsed_seconds", "backoff", "jitter"],
          "properties": {
            "maximum_attempts": { "type": "integer", "minimum": 0, "maximum": 20 },
            "maximum_elapsed_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
            "backoff": { "type": "string", "enum": ["none", "fixed", "exponential"] },
            "jitter": { "type": "boolean" }
          }
        },
        "failure_behavior": {
          "type": "string",
          "enum": ["fail-closed", "reject-new-work", "degrade-noncritical", "restart-bounded", "manual-recovery"]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "class": { "const": "realtime" } }, "required": ["class"] },
          "then": { "required": ["per_connection_memory_kib"] }
        },
        {
          "if": { "properties": { "default_enabled": { "const": true } }, "required": ["default_enabled"] },
          "then": {
            "properties": {
              "hard_limit": {
                "properties": {
                  "ocpu": { "maximum": 3 },
                  "memory_mib": { "maximum": 20480 },
                  "disk_gib": { "maximum": 180 }
                }
              }
            }
          }
        }
      ]
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ocpu", "memory_mib", "disk_gib"],
      "properties": {
        "ocpu": { "type": "number", "minimum": 0, "maximum": 4 },
        "memory_mib": { "type": "integer", "minimum": 0, "maximum": 24576 },
        "disk_gib": { "type": "number", "minimum": 0, "maximum": 200 }
      }
    }
  }
}
