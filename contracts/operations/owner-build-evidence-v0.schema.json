{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.liqi.internal/operations/owner-build-evidence-v0.schema.json",
  "title": "LIQI project-owner build evidence V0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "producer",
    "approval_ref",
    "gate_id",
    "git_sha",
    "command",
    "status",
    "exit_code",
    "started_at",
    "completed_at",
    "log_ref",
    "log_sha256"
  ],
  "properties": {
    "schema_version": {"const": "owner-build-evidence-v0"},
    "producer": {"const": "project-owner"},
    "approval_ref": {"type": "string", "minLength": 1, "maxLength": 256},
    "gate_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 512}
    },
    "status": {"enum": ["passed", "failed"]},
    "exit_code": {"type": "integer", "minimum": 0, "maximum": 255},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "log_ref": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+$", "maxLength": 512},
    "log_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "result_ref": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+$", "maxLength": 512},
    "result_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "allOf": [
    {
      "if": {"required": ["result_ref"]},
      "then": {"required": ["result_sha256"]}
    },
    {
      "if": {"required": ["result_sha256"]},
      "then": {"required": ["result_ref"]}
    },
    {
      "if": {"properties": {"status": {"const": "passed"}}, "required": ["status"]},
      "then": {"properties": {"exit_code": {"const": 0}}}
    },
    {
      "if": {"properties": {"status": {"const": "failed"}}, "required": ["status"]},
      "then": {"properties": {"exit_code": {"minimum": 1}}}
    }
  ]
}
